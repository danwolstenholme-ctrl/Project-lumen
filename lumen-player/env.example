# Lumen Player environment configuration.
# Copy to /etc/lumen-player/env (mode 600) on the Pi, fill in real values.

# Supabase project URL (e.g. https://abcd1234.supabase.co)
SUPABASE_URL=

# Service role key from Supabase dashboard - Settings > API.
# This is a high-privilege secret. Phase 2/3 will replace with a per-table JWT.
SUPABASE_SERVICE_KEY=

# UUID of this table's row in the `tables` table.
# Create the row in Supabase first, then paste its `id` here.
TABLE_ID=

# Local WebSocket port for the bench-test fallback transport. Default 8765.
# Production commands arrive via the Supabase Realtime channel instead.
WS_PORT=8765

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Unix socket path mpv uses for control.
MPV_IPC_SOCKET=/tmp/mpv-lumen.sock

# Optional mpv fullscreen display selector. Useful for a laptop + projector test.
# Try 0 or 1 if playback appears on the wrong display.
MPV_FULLSCREEN_SCREEN=
